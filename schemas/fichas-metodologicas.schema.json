{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/fichas-metodologicas.schema.json",
  "title": "Fichas metodologicas",
  "type": "object",
  "required": ["version", "ultimaRevisionGlobal", "criterioActualizacion", "fichas"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "ultimaRevisionGlobal": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "criterioActualizacion": { "type": "string", "minLength": 1 },
    "fichas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "titulo", "nivel", "estado", "ultimaRevision", "referentes", "usoDocente", "actividad", "evidencia", "salidaAlumno"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "titulo": { "type": "string", "minLength": 1 },
          "nivel": { "type": "string", "minLength": 1 },
          "estado": { "type": "string", "minLength": 1 },
          "ultimaRevision": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "referentes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "usoDocente": { "type": "string", "minLength": 1 },
          "actividad": { "type": "string", "minLength": 1 },
          "evidencia": { "type": "string", "minLength": 1 },
          "salidaAlumno": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
