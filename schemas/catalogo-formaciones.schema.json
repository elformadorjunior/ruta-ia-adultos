{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/catalogo-formaciones.schema.json",
  "title": "Catalogo de formaciones",
  "type": "object",
  "required": ["version", "fuenteBase", "nota", "formaciones"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "fuenteBase": { "type": "string", "minLength": 1 },
    "nota": { "type": "string", "minLength": 1 },
    "formaciones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["codigo", "denominacion", "familiaArea", "tipoPieza", "nivelEstimado", "publicoModalidad", "fuente", "observacionesPedagogicas"],
        "additionalProperties": false,
        "properties": {
          "codigo": { "type": "string", "minLength": 1 },
          "denominacion": { "type": "string", "minLength": 1 },
          "horas": { "type": ["integer", "null"], "minimum": 1 },
          "familiaArea": { "type": "string", "minLength": 1 },
          "tipoPieza": { "type": "string", "minLength": 1 },
          "nivelEstimado": { "type": "string", "minLength": 1 },
          "publicoModalidad": { "type": "string", "minLength": 1 },
          "fuente": {
            "type": "object",
            "required": ["etiqueta", "url"],
            "additionalProperties": false,
            "properties": {
              "etiqueta": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "minLength": 1 }
            }
          },
          "observacionesPedagogicas": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
